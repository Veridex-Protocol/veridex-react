{
  "name": "@veridex/react",
  "version": "1.0.0-beta.1",
  "description": "React hooks for Veridex Protocol SDK — passkeys, vaults, transfers, balances",
  "license": "MIT",
  "author": "Veridex Team",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@veridex/sdk": ">=1.0.0-beta.20",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.11",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "veridex",
    "react",
    "hooks",
    "passkey",
    "webauthn",
    "wallet",
    "web3"
  ]
}
